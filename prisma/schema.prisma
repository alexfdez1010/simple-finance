// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Product type enumeration
enum ProductType {
  YAHOO_FINANCE
  CUSTOM

  @@map("product_type")
}

/// Base model for all financial products
model FinancialProduct {
  id        String      @id @default(cuid())
  type      ProductType
  name      String
  quantity  Float
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  snapshots ProductSnapshot[]
  yahoo     YahooFinanceData?
  custom    CustomProductData?

  @@index([type])
  @@map("financial_products")
}

/// Yahoo Finance specific data
model YahooFinanceData {
  id            String   @id @default(cuid())
  productId     String   @unique
  symbol        String
  purchasePrice Float // Purchase price per share in EUR
  purchaseDate  DateTime // Date of purchase
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product FinancialProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([symbol])
  @@map("yahoo_finance_data")
}

/// Custom product specific data
model CustomProductData {
  id                String   @id @default(cuid())
  productId         String   @unique
  annualReturnRate  Float
  initialInvestment Float
  investmentDate    DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  currency          String   @default("EUR")

  product       FinancialProduct            @relation(fields: [productId], references: [id], onDelete: Cascade)
  contributions CustomProductContribution[]

  @@map("custom_product_data")
}

/// A single deposit (positive amount) or withdrawal (negative amount)
/// on a custom product. Each contribution accrues compound interest from
/// its own date at the product's annual return rate.
/// `amount` is stored in the parent product's currency; conversion to
/// other currencies is performed at display/aggregation time.
model CustomProductContribution {
  id                  String   @id @default(cuid())
  customProductDataId String
  amount              Float // Signed: > 0 = deposit, < 0 = withdrawal. In product currency.
  date                DateTime
  note                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  customProduct CustomProductData @relation(fields: [customProductDataId], references: [id], onDelete: Cascade)

  @@index([customProductDataId, date])
  @@map("custom_product_contributions")
}

/// Daily snapshot of product value
model ProductSnapshot {
  id        String   @id @default(cuid())
  productId String
  date      DateTime @db.Date
  value     Float
  quantity  Float
  createdAt DateTime @default(now())

  product FinancialProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@index([productId])
  @@index([date])
  @@map("product_snapshots")
}

/// Daily snapshot of total portfolio value
model PortfolioSnapshot {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  value     Float // Total portfolio value in EUR
  createdAt DateTime @default(now())

  @@index([date])
  @@map("portfolio_snapshots")
}
